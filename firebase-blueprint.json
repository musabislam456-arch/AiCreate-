{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Private user profile data",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "User's display name" },
        "email": { "type": "string", "format": "email", "description": "User's email address" },
        "avatar": { "type": "string", "format": "uri", "description": "URL to user's avatar" },
        "role": { "type": "string", "enum": ["user", "admin"], "description": "User's role" }
      },
      "required": ["name", "email", "avatar"]
    },
    "Comment": {
      "title": "Community Review",
      "description": "Public review or comment left by a user",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "UID of the user who wrote the review" },
        "userName": { "type": "string", "description": "Name of the user at the time of writing" },
        "userAvatar": { "type": "string", "description": "Avatar URL of the user at the time of writing" },
        "text": { "type": "string", "description": "The review content" },
        "rating": { "type": "number", "description": "Star rating (1-5)" },
        "createdAt": { "type": "number", "description": "Timestamp of creation" }
      },
      "required": ["userId", "userName", "userAvatar", "text", "rating", "createdAt"]
    },
    "HistoryItem": {
      "title": "Tool Usage History",
      "description": "Record of a tool being used by a user",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "UID of the user" },
        "toolId": { "type": "string", "description": "ID of the tool used" },
        "input": { "type": "string", "description": "Input provided to the tool" },
        "output": { "type": "string", "description": "Output generated by the tool" },
        "createdAt": { "type": "number", "description": "Timestamp of usage" }
      },
      "required": ["userId", "toolId", "input", "output", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Private user profiles"
    },
    "/comments/{commentId}": {
      "schema": "Comment",
      "description": "Public community reviews"
    },
    "/history/{historyId}": {
      "schema": "HistoryItem",
      "description": "Private tool usage history"
    }
  }
}
